# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App
NEXT_PUBLIC_APP_DOMAIN=laundryos.com

# Tap Payments (Phase 1)
# Get from https://business.tap.company → Developers → API Keys
TAP_SECRET_KEY=sk_test_...
TAP_WEBHOOK_SECRET=your-tap-webhook-hashstring
# NEXT_PUBLIC_TAP_PUBLIC_KEY is only needed if you use Tap.js hosted fields (Phase 1+ optional)
# NEXT_PUBLIC_TAP_PUBLIC_KEY=pk_test_...

# Supabase service-role key (server-only, NEVER expose client-side)
# Used only in webhook handlers that run outside a user session
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WhatsApp / Notifications (Phase 3)
# WHATSAPP_API_URL=
# WHATSAPP_TOKEN=
